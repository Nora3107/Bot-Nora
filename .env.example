# Discord Bot Token (Lấy từ Discord Developer Portal)
# Tạo tại: https://discord.com/developers/applications
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE

# Spotify API (Tùy chọn - để tối ưu tìm kiếm Spotify)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube Cookie (Tùy chọn - giúp bypass YouTube bot detection)
# Cách lấy: Mở YouTube trong trình duyệt > F12 > Network tab > Click request youtube.com > Copy giá trị Cookie header
# LƯU Ý: Dùng tài khoản PHỤ, không dùng tài khoản chính!
YOUTUBE_COOKIE=

# Port cho health check server (Render sẽ tự gán)
PORT=3000
